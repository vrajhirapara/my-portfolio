# Web3Forms: https://web3forms.com — register with the inbox where you want contact form mail.
#
# The production key is read from public/site-config.json at build time (and at runtime) unless you override with:
# Copy this file to .env.local, set VITE_WEB3FORMS_ACCESS_KEY, restart the dev server.
#
# Legacy CRA name still works: REACT_APP_WEB3FORMS_ACCESS_KEY (host build env or .env.local).
VITE_WEB3FORMS_ACCESS_KEY=
